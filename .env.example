# Gmail account used to send application emails (must be the authenticated sender)
GMAIL_USER=
# Gmail App Password (16 chars, no spaces) — NOT your normal account password
GMAIL_APP_PASSWORD=
# Discord invite link sent to applicants
DISCORD_INVITE_URL=
# Where the copy of each submission is sent (defaults to mish@icontraining.app)
NOTIFY_EMAIL=mish@icontraining.app
